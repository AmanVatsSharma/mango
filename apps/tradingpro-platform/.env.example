# MarketPulse360 - Environment Variables Configuration

# ===========================================
# APPLICATION URL (IMPORTANT!)
# ===========================================
# Set this to your production domain to fix order placement issues
# Leave unset in production and the app will auto-detect the correct URL
NEXT_PUBLIC_BASE_URL=https://www.marketpulse360.live

# For local development, use:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===========================================
# AUTHENTICATION
# ===========================================
NEXTAUTH_URL=https://www.marketpulse360.live
NEXTAUTH_SECRET=your-nextauth-secret-here
# Behind reverse proxy/CDN: required so forwarded host/proto are trusted (Auth.js v5).
# AUTH_TRUST_HOST=true
# NextAuth/JTI diagnostics: one-line JSON logs (prefixes only). Use 0 in production.
AUTH_SESSION_DEBUG=0
# Like AUTH_SESSION_DEBUG for middleware x-request-id + authSessionMw (optional split).
# AUTH_SESSION_DEBUG_TRACE=0
# Log GET /api/auth/session response hasUser/hasExpires: 1 in staging, or non-prod with AUTH_SESSION_DEBUG.
# AUTH_SESSION_ROUTE_AUDIT=0
# AUTH_SESSION_DEBUG_EDGE=0
# TRUSTED_PROXY_DEPTH=1
# SESSION_SECURITY_HMAC_SECRET=

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=your-database-url-here

# ===========================================
# CORS & SECURITY
# ===========================================
ALLOWED_ORIGINS=https://www.marketpulse360.live

# ===========================================
# DEPLOYMENT NOTES
# ===========================================
# 1. In AWS Lambda or non-Vercel deployments, ensure NEXT_PUBLIC_BASE_URL is set
# 2. In Vercel deployments, VERCEL_URL is automatically available
# 3. If both are unset, the app will use https://www.marketpulse360.live as fallback

# ===========================================
# MARKET DATA SERVICE (marketdata.vedpragya.com)
# ===========================================
# Base URL for the market-data NestJS backend (overrides built-in default)
MARKETDATA_BASE_URL=https://marketdata.vedpragya.com

# Admin token shared with the market-data service (same value as ADMIN_TOKEN set on
# the marketdata.vedpragya.com container). When set, the milli-search proxies add
# ?include=internal so responses include broker tokens (vortexToken/kiteToken) which
# are needed for watchlist saves and real-time WS subscriptions.
# Leave blank to use public-only search (no broker tokens in results).
MARKETDATA_ADMIN_TOKEN=your-marketdata-admin-token-here

# Optional: direct upstream base URL for the watchlist typeahead fast path.
# When set, milli-client calls suggest/search/filters/stream DIRECTLY from the browser,
# bypassing the Next.js BFF proxy hop entirely (~50-100ms saved per request) — this is
# what makes the watchlist search feel as fast as the marketdata admin dashboard.
#
# Requirements:
#   1. The upstream search-api must serve CORS headers for this app's origin. The
#      production search-api (apps/search-api/src/main.ts) allows tradebazar.live,
#      www.tradebazar.live, localhost:3000, localhost:3001, plus anything in its
#      CORS_ALLOWED_ORIGINS env var.
#   2. Direct calls return the PUBLIC response shape only — no broker tokens
#      (vortexToken/kiteToken/_internalProvider). That is fine because watchlist
#      saves persist `uirId` + `canonicalSymbol` (provider-agnostic). The BFF route
#      stays available as a fallback when this var is unset.
#
# Leave commented to use the BFF (slower, but works without CORS configuration).
# NEXT_PUBLIC_MARKETDATA_BASE_URL=https://marketdata.vedpragya.com

# ===========================================
# WEBSOCKET MARKET DATA
# ===========================================
LIVE_MARKET_WS_URL=ws://marketdata.vedpragya.com:3000/market-data
LIVE_MARKET_WS_API_KEY=your-api-key-here
NEXT_PUBLIC_ENABLE_WS_MARKET_DATA=true

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://127.0.0.1:6379
REDIS_POSITIONS_PNL_TTL_SECONDS=120
REDIS_POSITIONS_PNL_MAX_AGE_MS=15000

# ─── Risk Management Tunables ────────────────────────────────────────────────

# Max age (ms) for a Redis market-quote snapshot to be considered "live".
# Positions with quotes older than this fall back to the position-PnL worker tier.
# Default: 7500ms. Range: any non-negative integer (0 = always fresh, higher = more tolerant of stale quotes).
# REDIS_MARKET_QUOTE_MAX_AGE_MS=7500

# TTL (seconds) for writing market-quote snapshots to Redis.
# Controls how long a cached LTP entry survives in Redis before eviction.
# Default: 60s. Range: [10, 86400].
# REDIS_MARKET_QUOTE_TTL_SECONDS=60

# Max age (ms) for the in-process ServerMarketDataService quote cache.
# Quotes older than this are treated as stale and trigger a re-fetch or fallback.
# Default: 7500ms. Range: any non-negative integer.
# MARKETDATA_QUOTE_MAX_AGE_MS=7500

# Max age (ms) for the DB Stock.ltp fallback used by RiskMonitoringService.
# When no live quote is available, the risk monitor falls back to Stock.ltp only
# if its updatedAt is within this window; otherwise the position is skipped.
# Default: 300000ms (5 min). Range: [5000, 3600000].
# STOCK_LTP_FALLBACK_MAX_AGE_MS=300000

# How many minutes before NSE/MCX market close to begin intraday square-off.
# POSITION_INTRADAY_EOD_PRE_CLOSE_BUFFER_MINUTES is the canonical name;
# INTRADAY_EOD_PRE_CLOSE_BUFFER_MINUTES is a legacy alias (read as fallback).
# Default: 15 min. Range: [1, 120].
# POSITION_INTRADAY_EOD_PRE_CLOSE_BUFFER_MINUTES=15
# INTRADAY_EOD_PRE_CLOSE_BUFFER_MINUTES=15

# Enable verbose margin-calculation debug logging (MarginCalculator).
# Set to "1" or "true" to emit per-position margin details via the Pino logger.
# Default: off (any other value or unset). Use only in dev/staging — very chatty.
# MARGIN_CALC_DEBUG=1
