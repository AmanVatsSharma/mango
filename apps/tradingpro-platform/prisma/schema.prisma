model Withdrawal {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccountId String
  tradingAccount   TradingAccount   @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  bankAccountId    String
  bankAccount      BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  amount           Decimal          @db.Decimal(18, 2)
  status           WithdrawalStatus @default(PENDING)
  reference        String? // Reference number
  remarks          String?
  charges          Decimal          @default(0) @db.Decimal(18, 2)
  processedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // ─── Phase 13a — Risk-aware hold + approval-chain (additive) ───────────────────────────
  // Risk score is composed from the rules in `WithdrawalRiskRule` at *creation time* — the
  // snapshot is captured into `holdRuleKeys` so subsequent rule edits don't retroactively
  // change a queue row's reasoning. `approvalChain` is withdrawal-local on purpose: Phase 14
  // will introduce a generic `ApprovalRequest` later and we will migrate, but Phase 13a must
  // ship independently.
  /// Composite 0–100 score; ≥ holdThreshold (default 50) auto-routes to manual review.
  riskScore     Int       @default(0)
  /// Single-line summary of the dominant hold reason ("FIRST_WITHDRAWAL", "LARGE_VS_DEPOSIT", etc.)
  holdReason    String?   @db.VarChar(120)
  /// Snapshot of every rule_key that fired at evaluation time. Frozen at queue-time.
  holdRuleKeys  String[]  @default([])
  /// Multi-step approval ladder (RM → Ops → Super-Admin). Shape: [{stepIndex, role, approverId?, action, at, note}].
  /// JSON-on-row to keep Phase 13a self-contained; Phase 14 will lift this into ApprovalRequest.
  approvalChain Json      @default("[]")
  /// When the queue row first transitioned into HOLD/PENDING_REVIEW. Distinct from createdAt
  /// because a withdrawal can be flagged later (e.g. post-big-win rule fires after creation).
  heldAt        DateTime?
  /// When the hold was lifted (admin approve OR auto-release after cool-down). Null = still held.
  releasedAt    DateTime?

  // Phase 13b — surveillance back-edges. Cascade-delete on the alert row when the queue row
  // is deleted (we never want orphan alerts pointing at vanished withdrawals).
  surveillanceAlerts HouseSurveillanceAlert[] @relation("SurveillanceAlertWithdrawal")

  @@index([userId])
  @@index([tradingAccountId])
  @@index([status])
  @@index([createdAt])
  @@index([status, riskScore])
  @@index([heldAt])
  @@map("withdrawals")
}

