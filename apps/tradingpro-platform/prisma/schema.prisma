// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////
// Enums
//////////////////////////
enum Role {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycAmlStatus {
  PENDING
  CLEAR
  REVIEW
  HIT
}

enum KycSuspiciousStatus {
  NONE
  REVIEW
  ESCALATED
  CLEARED
}

enum KycReviewAction {
  ASSIGNED
  UNASSIGNED
  STATUS_UPDATED
  AML_UPDATED
  SUSPICIOUS_UPDATED
  NOTE_ADDED
}

enum ClientCrmNoteVisibility {
  TEAM
  MANAGER_ONLY
}

enum ClientCrmTaskKind {
  CALLBACK
  FOLLOW_UP
  DOCUMENT
  OTHER
}

enum ClientCrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ClientCrmTaskPriority {
  LOW
  NORMAL
  HIGH
}

enum ClientCrmTaskDisposition {
  NO_ANSWER
  CALLBACK_SCHEDULED
  WRONG_NUMBER
  SPOKE_FOLLOWUP
  OTHER
}

enum AuthEventType {
  REGISTRATION_ATTEMPT
  REGISTRATION_SUCCESS
  REGISTRATION_FAILED
  LOGIN_ATTEMPT
  LOGIN_SUCCESS
  LOGIN_FAILED
  OTP_SENT
  OTP_VERIFIED
  OTP_FAILED
  OTP_RESEND
  MPIN_SETUP_ATTEMPT
  MPIN_SETUP_SUCCESS
  MPIN_SETUP_FAILED
  MPIN_VERIFY_ATTEMPT
  MPIN_VERIFY_SUCCESS
  MPIN_VERIFY_FAILED
  MPIN_RESET_ATTEMPT
  MPIN_RESET_SUCCESS
  MPIN_RESET_FAILED
  SESSION_CREATED
  SESSION_EXPIRED
  SESSION_INVALIDATED
  PHONE_VERIFIED
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  SECURITY_VIOLATION
  RATE_LIMIT_EXCEEDED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  NETWORK_CLUSTER_ALERT
  CONCURRENT_SESSION_REJECTED
}

enum AuthEventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Referral bonus payout lifecycle
enum ReferralRewardStatus {
  PENDING
  ELIGIBLE
  PAID
  CANCELLED
  FROZEN
}

enum UserSessionKind {
  WEB_JWT
  MOBILE_SESSION_AUTH
  REGISTRATION_SIGHTING
}

enum SecurityIncidentType {
  MULTI_USER_SAME_NETWORK
  CONCURRENT_SESSIONS_EXCEEDED
  SESSION_POLICY_BLOCK
}

enum SecurityIncidentStatus {
  OPEN
  ACKNOWLEDGED
  FALSE_POSITIVE
  CLOSED
}

enum AccountType {
  LIVE
  DEMO
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  EXECUTED
  CANCELLED
}

/// OPEN = normal entry; CLOSE = queued exit leg executed via worker (Option A single-queue model).
enum OrderPurpose {
  OPEN
  CLOSE
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum OptionType {
  CE
  PE
  XX // Temporary: will be removed after data cleanup
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum LogCategory {
  ORDER
  POSITION
  TRANSACTION
  FUNDS
  AUTH
  SYSTEM
  API
}

enum OtpPurpose {
  LOGIN_VERIFICATION
  MPIN_SETUP
  MPIN_RESET
  PHONE_VERIFICATION
  TRANSACTION_AUTH
}

//////////////////////////
// NextAuth Models
//////////////////////////
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////////
// Core Models
//////////////////////////
model User {
  id                       String               @id @default(uuid())
  name                     String?
  email                    String?              @unique
  emailVerified            DateTime?            @map("email_verified")
  password                 String?
  image                    String?
  phone                    String?              @unique
  phoneVerified            DateTime?            @map("phone_verified")
  mPin                     String? // Encrypted mPin for trading
  bio                      String?
  role                     Role                 @default(USER)
  isActive                 Boolean              @default(true)
  /// Admin suspension (freeze); distinct from isActive (deactivated) and from eligibility policy tags.
  suspendedAt              DateTime?            @map("suspended_at")
  suspensionReason         String?              @map("suspension_reason") @db.VarChar(512)
  suspendedById            String?              @map("suspended_by_id")
  suspendedBy              User?                @relation("UserSuspensionActor", fields: [suspendedById], references: [id], onDelete: SetNull)
  usersSuspendedByThisUser User[]               @relation("UserSuspensionActor")
  requireOtpOnLogin        Boolean              @default(true) @map("require_otp_on_login")
  kyc                      KYC?
  tradingAccount           TradingAccount?
  accounts                 Account[] // NextAuth relation
  sessions                 Session[] // NextAuth relation
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @default(now()) @updatedAt
  clientId                 String?              @unique @map("client_id")
  PasswordResetToken       PasswordResetToken[]
  Watchlist                Watchlist[]
  OtpToken                 OtpToken[]
  SessionAuth              SessionAuth[]
  AuthEvents               AuthEvent[]

  // Console-specific relations
  bankAccounts BankAccount[]
  deposits     Deposit[]
  withdrawals  Withdrawal[]
  userProfile  UserProfile?

  // Relationship Manager (RM) self-relation
  managedById  String?
  managedBy    User?   @relation("UserRM", fields: [managedById], references: [id], onDelete: SetNull)
  managedUsers User[]  @relation("UserRM")

  // Referrals created by this user (typically admins)
  referralLinks ReferralLink[]

  // Owned scoped settings (per-admin/RM)
  ownedSettings SystemSettings[] @relation("UserOwnedSettings")

  // Enterprise features relations
  riskLimit            RiskLimit?
  riskAlerts           RiskAlert[]
  resolvedAlerts       RiskAlert[]    @relation("ResolvedAlerts")
  createdNotifications Notification[] @relation("CreatedNotifications")
  kycReviews           KycReviewLog[] @relation("KycReviewer")
  assignedKycs         KYC[]          @relation("KycAssignedTo")

  /// Optional client-facing RM contact overrides (when this user is an RM); null keys fall through to canonical User fields.
  rmPublicContact Json? @map("rm_public_contact")

  userSessionRecords              UserSessionRecord[]
  resolvedSecurityIncidents       SecurityIncident[]               @relation("SecurityIncidentResolvedBy")
  sessionSecurityStepUpChallenges SessionSecurityStepUpChallenge[]
  rmAssignmentRequests            RmAssignmentRequest[]            @relation("RmAssignmentRequestUser")
  resolvedRmAssignmentRequests    RmAssignmentRequest[]            @relation("RmAssignmentRequestResolvedBy")

  /// User who referred this account (denormalized from ReferralAttribution for fast admin queries).
  referredByUserId String? @map("referred_by_user_id")
  referredBy       User?   @relation("UserReferredBy", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers    User[]  @relation("UserReferredBy")

  referralAttributionsAsReferrer ReferralAttribution[]   @relation("AttributionReferrer")
  referralAttributionAsReferee   ReferralAttribution?    @relation("AttributionReferee")
  referralRuleSetsCreated        ReferralRuleSet[]       @relation("ReferralRuleSetCreator")
  referralRewardsAsBeneficiary   ReferralReward[]        @relation("ReferralRewardBeneficiary")
  referralUserPreference         ReferralUserPreference?

  clientCrmNotesAsSubject ClientCrmNote[] @relation("ClientCrmNoteSubject")
  clientCrmNotesAuthored  ClientCrmNote[] @relation("ClientCrmNoteAuthor")
  clientCrmTasksAsClient  ClientCrmTask[] @relation("ClientCrmTaskSubject")
  clientCrmTasksCreated   ClientCrmTask[] @relation("ClientCrmTaskCreator")
  clientCrmTasksCompleted ClientCrmTask[] @relation("ClientCrmTaskCompleter")

  // Segments & Policies
  segmentMemberships UserSegmentMember[]
  createdSegments    UserSegment[]       @relation("UserSegmentCreator")
  createdPolicies    TradingPolicy[]     @relation("TradingPolicyCreator")

  // Positions closed by this user (admin or retail)
  closedPositions Position[] @relation("PositionClosedBy")

  // Market-control personal override (Phase 2)
  marketControlOverride UserMarketControlOverride?

  // Risk audit trail
  riskAuditTargetEvents   RiskAuditEvent[] @relation("RiskAuditTarget")
  riskAuditOperatorEvents RiskAuditEvent[] @relation("RiskAuditOperator")

  // Phase 9 — Winner Mitigation (B-book counterparty defence)
  winnerControl                 ClientWinnerControl?
  winnerControlsUpdated         ClientWinnerControl[]        @relation("WinnerControlUpdater")
  winnerControlHistoryTriggered ClientWinnerControlHistory[] @relation("WinnerControlTrigger")
  tradeAdjustmentsPerformed     TradeAdjustmentLog[]         @relation("TradeAdjustmentPerformer")
  tradeAdjustmentsTargeted      TradeAdjustmentLog[]         @relation("TradeAdjustmentTarget")

  // Phase 10 — Bonus / Credit / Promo
  bonusGrantsAsBeneficiary BonusGrant[] @relation("BonusGrantBeneficiary")
  bonusGrantsIssued        BonusGrant[] @relation("BonusGrantIssuer")
  bonusRulesCreated        BonusRule[]  @relation("BonusRuleCreator")
  promoCodesCreated        PromoCode[]  @relation("PromoCodeCreator")

  // Phase 11 — Affiliate / IB program.
  // INVARIANT: these relations are ONLY for cascade behaviour + admin queries on the affiliate
  // module. They MUST NOT be pulled into trader-side RBAC / scoping queries (no `User.affiliateId`
  // back-edge on hot paths). Affiliate auth is its own surface (/api/affiliate/auth) and
  // affiliate identity is the `Affiliate` table — NOT the `User` enum.
  linkedAffiliate              Affiliate?             @relation("AffiliateLinkedUser")
  affiliateAttribution         AffiliateAttribution?  @relation("AffiliateAttributionClient")
  affiliateCommissionsAsSource AffiliateCommission[]  @relation("AffiliateCommissionSourceUser")
  affiliatesCreated            Affiliate[]            @relation("AffiliateCreator")
  affiliatesUpdated            Affiliate[]            @relation("AffiliateUpdater")
  affiliateAttributionsManual  AffiliateAttribution[] @relation("AffiliateAttributionAdmin")
  affiliatePayoutsApproved     AffiliatePayout[]      @relation("AffiliatePayoutApprover")
  affiliatePayoutsCreated      AffiliatePayout[]      @relation("AffiliatePayoutCreator")

  // Phase 12 — Communications engine.
  // INVARIANT: trader-side code MUST NOT pull `commsMessages` for a SELECT * on the user (the
  // table is high-volume; always paginate via the comms feed query). Consent is one row per
  // channel — see CommsConsent.@@unique([userId, channel]).
  commsConsents         CommsConsent[]       @relation("CommsConsentUser")
  commsMessages         CommsMessage[]       @relation("CommsMessageUser")
  campaignEnrollments   CampaignEnrollment[] @relation("CampaignEnrollmentUser")
  commsTemplatesCreated CommsTemplate[]      @relation("CommsTemplateCreator")
  commsCampaignsCreated CommsCampaign[]      @relation("CommsCampaignCreator")

  // Phase 13a — Withdrawal risk engine.
  // INVARIANT: rule authorship is admin-only metadata. Risk-score *evaluation* runs against
  // a snapshot of the rule set at evaluation time (`Withdrawal.holdRuleKeys`) — not by joining
  // these back-edges. The relations exist for "who last changed this rule" UX only.
  withdrawalRiskRulesCreated WithdrawalRiskRule[] @relation("WithdrawalRiskRuleCreator")
  withdrawalRiskRulesUpdated WithdrawalRiskRule[] @relation("WithdrawalRiskRuleUpdater")

  // Phase 13b — Internal Surveillance.
  // Subject side: alerts about THIS user. Admin side: alerts assigned to / dismissed by THIS user.
  // Rule authorship mirrors Phase 13a (createdBy / updatedBy on SurveillanceRule).
  surveillanceAlertsAbout     HouseSurveillanceAlert[] @relation("SurveillanceAlertSubject")
  surveillanceAlertsAssigned  HouseSurveillanceAlert[] @relation("SurveillanceAlertAssignee")
  surveillanceAlertsDismissed HouseSurveillanceAlert[] @relation("SurveillanceAlertDismisser")
  surveillanceRulesCreated    SurveillanceRule[]       @relation("SurveillanceRuleCreator")
  surveillanceRulesUpdated    SurveillanceRule[]       @relation("SurveillanceRuleUpdater")

  // Phase 14 — Push notifications (mobile)
  pushDevices PushDevice[]

  // Phase 15 — Homepage configuration (admin)
  homePageConfigsUpdated HomePageConfig[] @relation("HomePageConfigUpdater")

  @@index([managedById])
  @@index([suspendedById])
  @@index([referredByUserId])
  @@map("users")
}

model ClientCrmNote {
  id          String                  @id @default(uuid())
  userId      String                  @map("user_id")
  user        User                    @relation("ClientCrmNoteSubject", fields: [userId], references: [id], onDelete: Cascade)
  body        String                  @db.Text
  isPinned    Boolean                 @default(false) @map("is_pinned")
  visibility  ClientCrmNoteVisibility @default(TEAM) @map("visibility")
  createdById String                  @map("created_by_id")
  createdBy   User                    @relation("ClientCrmNoteAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("client_crm_notes")
}

model ClientCrmTask {
  id            String                    @id @default(uuid())
  userId        String                    @map("user_id")
  user          User                      @relation("ClientCrmTaskSubject", fields: [userId], references: [id], onDelete: Cascade)
  title         String                    @db.VarChar(512)
  description   String?                   @db.Text
  kind          ClientCrmTaskKind
  status        ClientCrmTaskStatus       @default(OPEN)
  priority      ClientCrmTaskPriority     @default(NORMAL)
  dueAt         DateTime?                 @map("due_at")
  snoozeCount   Int                       @default(0) @map("snooze_count")
  disposition   ClientCrmTaskDisposition? @map("disposition")
  outcomeNote   String?                   @map("outcome_note") @db.Text
  createdById   String                    @map("created_by_id")
  createdBy     User                      @relation("ClientCrmTaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  completedById String?                   @map("completed_by_id")
  completedBy   User?                     @relation("ClientCrmTaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt   DateTime?                 @map("completed_at")
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@index([userId, status, dueAt])
  @@index([userId, dueAt])
  @@map("client_crm_tasks")
}

model KYC {
  id               String              @id @default(uuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  aadhaarNumber    String
  panNumber        String
  bankProofUrl     String
  bankProofKey     String?
  status           KycStatus           @default(PENDING)
  assignedToId     String?             @map("assigned_to_id")
  assignedTo       User?               @relation("KycAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt       DateTime?           @map("assigned_at")
  slaDueAt         DateTime?           @map("sla_due_at")
  slaBreachedAt    DateTime?           @map("sla_breached_at")
  amlStatus        KycAmlStatus        @default(PENDING) @map("aml_status")
  amlFlags         String[]            @default([]) @map("aml_flags")
  suspiciousStatus KycSuspiciousStatus @default(NONE) @map("suspicious_status")
  submittedAt      DateTime            @default(now())
  approvedAt       DateTime?
  updatedAt        DateTime            @updatedAt
  reviewLogs       KycReviewLog[]

  @@index([status])
  @@index([assignedToId])
  @@index([slaDueAt])
  @@index([amlStatus])
  @@index([suspiciousStatus])
  @@map("kyc")
}

model KycReviewLog {
  id         String          @id @default(uuid())
  kycId      String          @map("kyc_id")
  kyc        KYC             @relation(fields: [kycId], references: [id], onDelete: Cascade)
  reviewerId String?         @map("reviewer_id")
  reviewer   User?           @relation("KycReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  action     KycReviewAction
  note       String?
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([kycId])
  @@index([reviewerId])
  @@index([action])
  @@index([createdAt])
  @@map("kyc_review_logs")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([email, token])
}

model Stock {
  id            String   @id @default(cuid())
  instrumentId  String   @unique
  symbol        String
  exchange      String
  ticker        String
  name          String
  segment       String // NSE, NFO
  ltp           Float    @default(0)
  open          Float    @default(0)
  high          Float    @default(0)
  low           Float    @default(0)
  close         Float    @default(0)
  volume        Int      @default(0)
  change        Float    @default(0)
  changePercent Float    @default(0)
  sector        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt()

  // F&O specific fields
  strikePrice Decimal?    @db.Decimal(10, 2) // Only for options
  optionType  OptionType? // CE/PE, only for options
  expiry      DateTime? // Only for F&O
  lot_size    Float?

  // Instrument token from market data API
  token Int? @unique

  // Provider-agnostic UIR id from milli-search — used as quote map key (gateway emits uirId on every tick)
  uirId           Int?
  // Provider-agnostic canonical symbol e.g. "NSE:RELIANCE" — used for WS { symbols: [...] } subscribe
  canonicalSymbol String?

  // watchlistItems WatchlistItem[]
  orders    Order[]
  positions Position[]

  @@index([token])
}

model Watchlist {
  id          String   @id @default(uuid())
  userId      String
  name        String   @default("My Watchlist")
  description String?
  color       String?  @default("#3B82F6") // Hex color for watchlist theme
  isDefault   Boolean  @default(false) // Mark default watchlist
  isPrivate   Boolean  @default(false) // Private vs public watchlist
  sortOrder   Int      @default(0) // Custom sort order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@unique([userId, name])
  @@index([userId, sortOrder])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  stockId     String? // Optional, kept for backward compatibility
  notes       String? // User notes for this stock
  alertPrice  Decimal? @db.Decimal(10, 2) // Price alert threshold
  alertType   String?  @default("ABOVE") // ABOVE, BELOW, BOTH
  sortOrder   Int      @default(0) // Custom sort order within watchlist
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Instrument token from market data API (unique identifier)
  token Int?

  // Instrument data stored directly in WatchlistItem (no Stock dependency)
  symbol   String? @default("UNKNOWN") // Temporarily nullable for migration
  exchange String? @default("NSE") // Temporarily nullable for migration
  segment  String? @default("NSE") // Temporarily nullable for migration
  name     String? @default("Unknown") // Temporarily nullable for migration
  ltp      Float   @default(0)
  close    Float   @default(0)

  // Provider-agnostic UIR id from milli-search — used as quote map key (gateway emits uirId on every tick)
  uirId           Int?
  // Provider-agnostic canonical symbol e.g. "NSE:RELIANCE" — used for WS { symbols: [...] } subscribe
  canonicalSymbol String?

  // F&O specific fields
  strikePrice Decimal?    @db.Decimal(10, 2) // Only for options
  optionType  OptionType? // CE/PE, only for options
  expiry      DateTime? // Only for F&O
  lotSize     Float?

  // Instrument classification — EQ | FUT | CE | PE | IDX | ETF | SPOT | …
  // Persisted so badges / order routing can resolve the asset class without re-parsing
  // canonicalSymbol or guessing from segment suffixes. Nullable so existing rows continue
  // to work — the watchlist UI falls back to canonicalSymbol-based recovery when null.
  instrumentType String?
  logo_url       String?

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  // stock     Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade) // Commented out - no longer used

  @@unique([watchlistId, token])
  @@index([watchlistId, sortOrder])
  @@index([token])
}

model TradingAccount {
  id              String      @id @default(uuid())
  userId          String      @unique
  accountType     AccountType @default(LIVE)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Int         @default(0)
  availableMargin Int         @default(0)
  usedMargin      Int         @default(0)
  /// Phase 10 — non-withdrawable credit balance from bonuses. Stored in rupees (Int) to
  /// match existing balance columns on this table. Burndown via lib/bonus/burndown.ts on
  /// settled trades; advances turnoverProgress on linked BonusGrant rows.
  creditBalance   Int         @default(0) @map("credit_balance")
  clientId        String?     @unique @map("client_id")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt

  orders      Order[]
  positions   Position[]
  trades      Transaction[]
  deposits    Deposit[]
  withdrawals Withdrawal[]

  @@unique([userId, accountType])
  @@index([accountType])
  @@map("trading_accounts")
}

model Order {
  id               String       @id @default(uuid())
  tradingAccountId String
  symbol           String
  quantity         Int
  orderType        OrderType
  orderSide        OrderSide
  price            Decimal?     @db.Decimal(10, 2)
  filledQuantity   Int          @default(0)
  averagePrice     Decimal?     @db.Decimal(10, 2)
  productType      String       @default("MIS")
  status           OrderStatus  @default(PENDING)
  orderPurpose     OrderPurpose @default(OPEN)
  closeMetadata    Json?
  failureCode      String?
  failureReason    String?
  /// Rupees (integer) reserved at placement; released on cancel or moved at fill.
  blockedMargin    Int          @default(0)
  /// Rupees charged at placement (brokerage/taxes); refunded on cancel when order never executes.
  placementCharges Int          @default(0)
  /// Snapshot of EffectiveControls captured at placement time — spread %, slippage %, tilt bias, user-group, symbol override. Used by the worker to replay the same market-control rules at fill time.
  executionContext Json?
  createdAt        DateTime     @default(now())
  executedAt       DateTime?

  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  Stock          Stock?         @relation(fields: [stockId], references: [id])
  stockId        String?
  Position       Position?      @relation(fields: [positionId], references: [id])
  positionId     String?
  // Reverse relation to transactions linked to this order
  transactions   Transaction[]

  @@index([status, orderPurpose, createdAt])
  @@map("orders")
}

model Transaction {
  id               String          @id @default(uuid())
  tradingAccountId String
  amount           Decimal         @db.Decimal(18, 2)
  type             TransactionType
  description      String?
  createdAt        DateTime        @default(now())

  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  // Link transactions to specific orders/positions when applicable
  orderId        String?
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  positionId     String?
  position       Position?      @relation(fields: [positionId], references: [id], onDelete: SetNull)

  // Phase 13b — surveillance back-edges (e.g. SUSPICIOUS_WINNER references the closing TXN).
  surveillanceAlerts HouseSurveillanceAlert[] @relation("SurveillanceAlertTransaction")

  @@index([orderId])
  @@index([positionId])
  @@map("transactions")
}

model Position {
  id               String      @id @default(uuid())
  tradingAccountId String
  symbol           String
  productType      String      @default("MIS")
  isIntraday       Boolean     @default(true)
  instrumentId     String?
  segment          String?
  exchange         String?
  strikePrice      Decimal?    @db.Decimal(10, 2)
  optionType       OptionType?
  expiry           DateTime?
  token            Int?
  uirId            Int?
  canonicalSymbol  String?
  quantity         Int
  averagePrice     Decimal     @db.Decimal(10, 2)
  unrealizedPnL    Decimal     @default(0) @db.Decimal(18, 2)
  dayPnL           Decimal     @default(0) @db.Decimal(18, 2)
  stopLoss         Decimal?    @db.Decimal(10, 2)
  target           Decimal?    @db.Decimal(10, 2)
