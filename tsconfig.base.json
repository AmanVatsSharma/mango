{
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "target": "ES2023",
    "module": "ESNext",
    "lib": ["ES2023"],
    "baseUrl": ".",
    "paths": {
      "@mango/shared-types": ["libs/shared/types/src/index.ts"],
      "@mango/shared-utils": ["libs/shared/utils/src/index.ts"],
      "@obsidian/backend-auth": ["apps/backend/src/modules/auth/index.ts"],
      "@obsidian/backend-accounts": ["apps/backend/src/modules/accounts/index.ts"],
      "@obsidian/backend-admin": ["apps/backend/src/modules/admin/index.ts"],
      "@obsidian/backend-users": ["apps/backend/src/modules/users/index.ts"],
      "@obsidian/backend-rbac": ["apps/backend/src/modules/rbac/index.ts"],
      "@obsidian/backend-market": ["apps/backend/src/modules/market/index.ts"],
      "@obsidian/backend-oms": ["apps/backend/src/modules/oms/index.ts"],
      "@obsidian/backend-notifications": ["apps/backend/src/modules/notifications/index.ts"],
      "@obsidian/backend-onboarding": ["apps/backend/src/modules/onboarding/index.ts"],
      "@obsidian/backend-compliance": ["apps/backend/src/modules/compliance/index.ts"],
      "@obsidian/backend-broker-hierarchy": ["apps/backend/src/modules/broker-hierarchy/index.ts"],
      "@obsidian/backend-execution-gateway": ["apps/backend/src/modules/execution-gateway/index.ts"],
      "@obsidian/backend-corporate-actions": ["apps/backend/src/modules/corporate-actions/index.ts"],
      "@obsidian/backend-dealing": ["apps/backend/src/modules/dealing/index.ts"],
      "@obsidian/backend-demo-accounts": ["apps/backend/src/modules/demo-accounts/index.ts"],
      "@obsidian/backend-developer-platform": ["apps/backend/src/modules/developer-platform/index.ts"],
      "@obsidian/backend-limits-controls": ["apps/backend/src/modules/limits-and-controls/index.ts"],
      "@obsidian/backend-partners": ["apps/backend/src/modules/partners/index.ts"],
      "@obsidian/backend-realtime": ["apps/backend/src/modules/realtime/prana-stream/index.ts"],
      "@obsidian/backend-reconciliation": ["apps/backend/src/modules/reconciliation/index.ts"],
      "@obsidian/backend-risk-policy": ["apps/backend/src/modules/risk-policy/index.ts"],
      "@obsidian/backend-saas-control-plane": ["apps/backend/src/modules/saas-control-plane/index.ts"],
      "@obsidian/backend-settlement": ["apps/backend/src/modules/settlement/index.ts"],
      "@obsidian/backend-support": ["apps/backend/src/modules/support/index.ts"],
      "@obsidian/backend-tenancy": ["apps/backend/src/modules/tenancy/index.ts"],
      "@obsidian/backend-shared": ["apps/backend/src/shared/index.ts"],
      "@obsidian/backend-common": ["apps/backend/src/common/index.ts"],
      "@app/shared-types": ["libs/shared/types/src/index.ts"],
      "@app/shared-utils": ["libs/shared/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".nx"]
}